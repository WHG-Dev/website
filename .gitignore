# Ignore everything by default
#*

# But keep git metadata and this file
!.gitignore
!.gitattributes
node_modules/
# Keep common top-level project files and lockfiles
!README.md
!LICENSE
!package.json
!package-lock.json
!yarn.lock
!pnpm-lock.yaml
!pyproject.toml
!requirements.txt
!setup.py
!Pipfile
!Pipfile.lock
!Makefile
!go.mod
!go.sum
!tsconfig.json

# Keep common solution/project files
!*.sln
!*.csproj

# Keep common entrypoints
!index.html
!index.js
!index.ts
!app.js
!main.py
!manage.py

# Allow typical source and config directories and all their contents
!/src/
!/src/**
!/lib/
!/lib/**
!/app/
!/app/**
!/public/
!/public/**
!/pages/
!/pages/**
!/components/
!/components/**
!/cmd/
!/cmd/**
!/bin/
!/bin/**
!/tests/
!/tests/**
!/spec/
!/spec/**

# Keep dotfiles that are often essential
!.env
!.env.example
!.npmrc
!.nvmrc
!.tool-versions